# Cấu hình Podfile cho iOS 16.0+ (Tích hợp Flutter Helper)
platform :ios, '16.0'

# Quan trọng: Dòng này giúp Podfile hiểu được các lệnh như 'flutter_install_all_ios_pods'
load File.join(File.dirname(File.realpath(__FILE__)), 'Flutter', 'podhelper.rb')

install! 'cocoapods', :deterministic_uuids => false

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  # Lệnh này bây giờ đã được định nghĩa nhờ dòng 'load' ở trên
  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    
    target.build_configurations.each do |config|
      config.build_settings['DEBUG_INFORMATION_FORMAT'] = 'dwarf'
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '16.0'
      config.build_settings['ENABLE_USER_SCRIPT_SANDBOXING'] = 'NO'
    end
  end
end
